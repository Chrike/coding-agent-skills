{
  "$schema": "coding-agent-skills-lifecycle-policy-v1",
  "schema_version": "lifecycle-policy-v1",
  "status": "blocked-awaiting-product-task-and-harness",
  "runtime_installable": false,
  "outcome_claims": "none",
  "automatic_lifecycle_actions": false,
  "allowed_advisory_statuses": [
    "inconclusive",
    "retain-current",
    "candidate-for-human-review",
    "blocked"
  ],
  "required_recovery_prerequisites": [
    "real-product-task-specification",
    "independent-pre-frozen-acceptance-oracle",
    "immutable-task-harness",
    "verifiable-host-provider-tool-policy-contract",
    "fresh-session-context-workspace-isolation",
    "provenance-and-attempt-metadata",
    "provider-backed-telemetry",
    "pinned-pricing-source-and-version"
  ],
  "first_future_execution": {
    "scenario_count": 1,
    "provider_count": 1,
    "host_count": 1,
    "comparison": ["base-only", "baseline", "candidate"],
    "mode": "advisory-only-smoke-proof",
    "lifecycle_action": "none"
  },
  "maintainer_review_required": true,
  "automatic_actions": {
    "promotion": false,
    "demotion": false,
    "archive": false,
    "profile_mutation": false,
    "routing_mutation": false,
    "path_mutation": false,
    "install_mutation": false
  }
}
